<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <RecipeDef>
        <defName>ABF_Recipe_Justiciar_MakeMirrorNecklace</defName>
        <label>make mirror necklace</label>
        <description>Carve a mirror necklace from obsidian glass.</description>
        <jobString>Carving mirror necklace.</jobString>
        <effectWorking>Sculpt</effectWorking>
        <soundWorking>Recipe_Sculpt</soundWorking>
        <workAmount>12000</workAmount>
        <workSkill>Artistic</workSkill>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <unfinishedThingDef>UnfinishedSculpture</unfinishedThingDef>
        <useIngredientsForColor>false</useIngredientsForColor>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Obsidian</li>
                    </thingDefs>
                </filter>
                <count>20</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Obsidian</li>
            </thingDefs>
        </fixedIngredientFilter>
        <recipeUsers>
            <li>JDG_Thing_Justiciar_Altar</li>
        </recipeUsers>
        <products>
            <ABF_Thing_Justiciar_MirrorNecklace>1</ABF_Thing_Justiciar_MirrorNecklace>
        </products>
    </RecipeDef>

