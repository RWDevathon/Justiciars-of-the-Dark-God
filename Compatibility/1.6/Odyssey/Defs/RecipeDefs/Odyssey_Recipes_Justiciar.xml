    <RecipeDef>
        <defName>ABF_Recipe_Justiciar_RefineObsidianFromGranite</defName>
        <label>smelt granite for obsidian shards</label>
        <description>Obsidian is a volcanic glass, but with sufficient heat, pressure, and power, a granite chunk - made of igneous rock like obsidian - can be melted down for a few precious shards of the beautiful material.</description>
        <jobString>Melting granite.</jobString>
        <effectWorking>Smelt</effectWorking>
        <soundWorking>Recipe_Smelt</soundWorking>
        <workAmount>1600</workAmount>
        <workSkill>Crafting</workSkill>
        <workSpeedStat>SmeltingSpeed</workSpeedStat>
        <workSkillLearnFactor>0</workSkillLearnFactor>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>ChunkGranite</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>ChunkGranite</li>
            </thingDefs>
        </fixedIngredientFilter>
        <recipeUsers>
            <li>ElectricSmelter</li>
        </recipeUsers>
        <products>
            <Obsidian>3</Obsidian>
        </products>
    </RecipeDef>

</Defs>