<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <ThingDef ParentName="BenchBase">
        <defName>JDG_Thing_Justiciar_Altar</defName>
        <label>altar</label>
        <description>An obsidian altar with both ceremonial and practical tools for a justiciar.</description>
        <thingClass>ArtificialBeings.Building_JusticiarAltar</thingClass>
        <graphicData>
            <texPath>Things/Building/Production/TableSculpting</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <shaderType>CutoutComplex</shaderType>
            <drawSize>(3.5,1.5)</drawSize>
            <shadowData>
                <volume>(2.9, 0.3, 0.5)</volume>
                <offset>(0, 0, 0)</offset>
            </shadowData>
            <damageData>
                <cornerTL>Damage/Corner</cornerTL>
                <cornerTR>Damage/Corner</cornerTR>
                <cornerBL>Damage/Corner</cornerBL>
                <cornerBR>Damage/Corner</cornerBR>
            </damageData>
            <color>(0.2, 0.2, 0.2)</color>
        </graphicData>
        <costList>
            <Obsidian>75</Obsidian>
        </costList>
        <altitudeLayer>Building</altitudeLayer>
        <fillPercent>0.5</fillPercent>
        <useHitPoints>True</useHitPoints>
        <statBases>
            <WorkToBuild>2500</WorkToBuild>
            <MaxHitPoints>40</MaxHitPoints>
            <Beauty>8</Beauty>
            <Flammability>0</Flammability>
            <Cleanliness>0</Cleanliness>
        </statBases>
        <size>(3,1)</size>
        <designationCategory>Production</designationCategory>
        <passability>PassThroughOnly</passability>
        <pathCost>50</pathCost>
        <hasInteractionCell>True</hasInteractionCell>
        <interactionCellOffset>(0,0,-1)</interactionCellOffset>
        <surfaceType>Item</surfaceType>
        <inspectorTabs>
            <li>ITab_Bills</li>
        </inspectorTabs>
        <building>
            <spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
            <paintable>true</paintable>
        </building>
        <designationHotKey>Misc2</designationHotKey>
        <placeWorkers>
            <li>PlaceWorker_PreventInteractionSpotOverlap</li>
        </placeWorkers>
    </ThingDef>

</Defs>