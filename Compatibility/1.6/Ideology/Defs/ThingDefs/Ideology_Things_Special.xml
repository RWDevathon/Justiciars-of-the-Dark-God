<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <ThingDef ParentName="TreeBase">
        <defName>ABF_Thing_Justiciar_UmbralAnchor</defName>
        <label>umbral anchor</label>
        <description>A larged, distinctive-looking tree that has been warped by dark powers. No longer truly living, this tree is an anchor point tied to a domain of pure darkness. Through this tenuous connection, a shadespirit can be drawn and forced to take physical form. Utterly loyal to the justiciars of this plane, the creature will serve without question for as long as its form is intact. The anchor's ephemeral bond to the domain of darkness means it can sustain only one shadespirit at a time, and can only manifest a singular creature every quadrum should one perish.</description>
        <graphicData>
            <texPath>Justiciars/Ideology/Things/Trees/UmbralAnchor</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shadowData>
                <volume>(0.21, 0.6, 0.21)</volume>
            </shadowData>
        </graphicData>
        <tickerType>Long</tickerType>
        <canScatterOver>false</canScatterOver>
        <descriptionHyperlinks>
            <ThingDef>ABF_Thing_Justiciar_CorruptedGauranlenSeed</ThingDef>
        </descriptionHyperlinks>
        <minifiedDef IsNull="True" />
        <statBases>
            <Beauty>6</Beauty>
            <BeautyOutdoors>6</BeautyOutdoors>
            <Flammability>1</Flammability>
            <MaxHitPoints>300</MaxHitPoints>
        </statBases>
        <ingestible />
        <preventSkyfallersLandingOn>true</preventSkyfallersLandingOn>
        <notifyMapRemoved>true</notifyMapRemoved>
        <plant>
            <growDays>1</growDays>
            <visualSizeRange>1.5~2.1</visualSizeRange>
            <sowMinSkill>0</sowMinSkill>
            <sowTags Inherit="False"/>
            <lifespanDaysPerGrowDays>0</lifespanDaysPerGrowDays>
            <completelyIgnoreFertility>true</completelyIgnoreFertility>
            <fertilityMin>0</fertilityMin>
            <fertilitySensitivity>0</fertilitySensitivity>
            <wildClusterWeight>0</wildClusterWeight>
            <sowWork>400</sowWork>
            <harvestYield>35</harvestYield>
            <treeCategory>Super</treeCategory>
            <dieIfNoSunlight>false</dieIfNoSunlight>
            <interferesWithRoof>false</interferesWithRoof>
            <growMinGlow>0</growMinGlow>
            <growOptimalGlow>0</growOptimalGlow>
            <minGrowthTemperature>-200</minGrowthTemperature>
            <minOptimalGrowthTemperature>-200</minOptimalGrowthTemperature>
            <maxGrowthTemperature>200</maxGrowthTemperature>
            <maxOptimalGrowthTemperature>200</maxOptimalGrowthTemperature>
            <sowResearchPrerequisites Inherit="False" />
            <dieFromToxicFallout>False</dieFromToxicFallout>
            <showGrowthInInspectPane>false</showGrowthInInspectPane>
            <minSpacingBetweenSamePlant>1.9</minSpacingBetweenSamePlant>
            <warnIfMarkedForCut>true</warnIfMarkedForCut>
            <choppedThingDef>ABF_Thing_Justiciar_ChoppedStump_UmbralAnchor</choppedThingDef>
            <smashedThingDef>ABF_Thing_Justiciar_SmashedStump_UmbralAnchor</smashedThingDef>
        </plant>
        <comps>
            <li Class="CompProperties_SelfhealHitpoints">
                <ticksPerHeal>2000</ticksPerHeal> <!-- 30 hp per day, must be a multiple of 2000, since plants have Long ticker -->
            </li>
            <li Class="ArtificialBeings.ThingCompProperties_UmbralAnchor">
                <daysBetweenSpawns>15</daysBetweenSpawns>
            </li>
            <li Class="CompProperties_PlantPreventCutting"/>
        </comps>
    </ThingDef>

    <ThingDef ParentName="StumpChoppedBase">
        <defName>ABF_Thing_Justiciar_ChoppedStump_UmbralAnchor</defName>
        <label>chopped umbral anchor stump</label>
        <description>A stump left behind after an umbral anchor has been felled. The stump can be extracted but yields very little usable wood. Left outdoors, the stump will deteriorate in time.</description>
        <graphicData>
            <texPath>Justiciars/Ideology/Things/Trees/UmbralAnchor_ChoppedStump</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
    </ThingDef>

    <ThingDef ParentName="StumpSmashedBase">
        <defName>ABF_Thing_Justiciar_SmashedStump_UmbralAnchor</defName>
        <label>smashed umbral anchor stump</label>
        <description>The remnants of an umbral anchor destroyed by damage. It's ugly. The stump can be extracted but yields very little usable wood. Left outdoors, the stump will deteriorate in time.</description>
        <graphicData>
            <texPath>Justiciars/Ideology/Things/Trees/UmbralAnchor_SmashedStump</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
    </ThingDef>

    <ThingDef ParentName="ResourceBase">
        <defName>ABF_Thing_Justiciar_CorruptedGauranlenSeed</defName>
        <label>corrupted gauranlen seed</label>
        <description>The corrupted seed of a gauranlen tree. It can be planted to create an umbral anchor capable of tethering a dark creature to this plane of existence.</description>
        <descriptionHyperlinks>
            <ThingDef>ABF_Thing_Justiciar_UmbralAnchor</ThingDef>
        </descriptionHyperlinks>
        <stackLimit>5</stackLimit>
        <statBases>
            <MaxHitPoints>50</MaxHitPoints>
            <Mass>0.3</Mass>
            <Beauty>0</Beauty>
            <MarketValue>70</MarketValue>
        </statBases>
        <graphicData>
            <texPath>Justiciars/Ideology/Things/UmbralAnchorSeeds</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
            <drawSize>(0.6, 0.6)</drawSize>
        </graphicData>
        <thingCategories>
            <li>ItemsMisc</li>
        </thingCategories>
        <comps>
        <li Class="CompProperties_Plantable">
            <plantDefToSpawn>ABF_Thing_Justiciar_UmbralAnchor</plantDefToSpawn>
        </li>
        </comps>
    </ThingDef>

</Defs>