        <race>ABF_Thing_Justiciar_Perceptor</race>
        <lifeStages>
            <li>
                <bodyGraphicData>
                    <texPath>Things/Pawn/Animal/Dryad_Medicinemaker/DryadMedicinemaker</texPath>
                    <drawSize>1.5</drawSize>
                    <color>(0.2, 0.2, 0.2)</color>
                </bodyGraphicData>
                <dessicatedBodyGraphicData>
                    <texPath>Things/Pawn/Animal/Dryad_Medicinemaker/Dessicated_DryadMedicinemaker</texPath>
                    <drawSize>1.5</drawSize>
                    <color>(0.2, 0.2, 0.2)</color>
                </dessicatedBodyGraphicData>
            </li>
        </lifeStages>
    </PawnKindDef>

    <PawnKindDef ParentName="ABF_PawnKind_Justiciar_Player_CreatureBase">
