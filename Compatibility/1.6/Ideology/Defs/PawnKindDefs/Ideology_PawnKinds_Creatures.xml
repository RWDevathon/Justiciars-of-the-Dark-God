        <startingHediffs>
            <li>
                <def>ABF_Hediff_Justiciar_ShadeSpirit</def>
            </li>
        </startingHediffs>
    </PawnKindDef>

    <PawnKindDef ParentName="ABF_PawnKind_Justiciar_Player_CreatureBase">
