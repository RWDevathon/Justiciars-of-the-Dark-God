<?xml version="1.0" encoding="UTF-8"?>
<Patch>

    <!-- Biotech Mech Boss drops and mechlinks are clonable -->

    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[defName="SignalChip"]</xpath>
        <value>
            <li Class="ArtificialBeings.UmbralClonableExtension">
                <favorCost>50</favorCost>
            </li>
        </value>
    </Operation>

    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[defName="PowerfocusChip"]</xpath>
        <value>
            <li Class="ArtificialBeings.UmbralClonableExtension">
                <favorCost>100</favorCost>
            </li>
        </value>
    </Operation>

    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[defName="NanostructuringChip"]</xpath>
        <value>
            <li Class="ArtificialBeings.UmbralClonableExtension">
                <favorCost>150</favorCost>
            </li>
        </value>
    </Operation>

    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[defName="Mechlink"]</xpath>
        <value>
            <li Class="ArtificialBeings.UmbralClonableExtension">
                <favorCost>100</favorCost>
            </li>
        </value>
    </Operation>

    <!-- Polux seeds can be corrupted -->

    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="PoluxSeed"]/comps</xpath>
        <value>
            <li Class="ArtificialBeings.ThingCompProperties_Corruptible">
                <defToSpawn>ABF_Thing_Justiciar_CorruptedPoluxSeed</defToSpawn>
            </li>
        </value>
    </Operation>

</Patch>