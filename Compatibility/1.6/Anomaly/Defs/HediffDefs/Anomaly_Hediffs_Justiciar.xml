<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <HediffDef>
        <defName>ABF_Hediff_Justiciar_BioferriteWeakness</defName>
        <hediffClass>Hediff</hediffClass>
        <label>bioferrite weakness</label>
        <description>This creature is feeling ill due to exposure to bioferrite - anathema to justiciars. It may take some time for the justiciar to recover from this illness after avoiding further exposure.</description>
        <stages>
            <li>
                <label>weakened</label>
                <painOffset>0.1</painOffset>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <postFactor>0.8</postFactor>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <HediffDef>
        <defName>ABF_Hediff_Justiciar_BioferritePoisoning</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>bioferrite weakness</label>
        <description>This justiciar is feeling ill due to ingesting bioferrite - a substance anathemic to them.</description>
        <comps>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>30000</disappearsAfterTicks>
                <showRemainingTime>true</showRemainingTime>
            </li>
        </comps>
        <stages>
            <li>
                <label>sickened</label>
                <painOffset>0.2</painOffset>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <postFactor>0.75</postFactor>
                    </li>
                    <li>
                        <capacity>Moving</capacity>
                        <postFactor>0.75</postFactor>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <postFactor>0.9</postFactor>
                    </li>
                    <li>
                        <capacity>BloodFiltration</capacity>
                        <postFactor>0.95</postFactor>
                    </li>
                    <li>
                        <capacity>Talking</capacity>
                        <postFactor>0.9</postFactor>
                    </li>
                    <li>
                        <capacity>Eating</capacity>
                        <postFactor>0.5</postFactor>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

</Defs>